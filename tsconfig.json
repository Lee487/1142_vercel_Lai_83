{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
, "src/app/grocery_83/_components/Items_xx.jsx", "src/app/grocery_83/_components/Form_xx.jsx", "src/app/_assets/wrapper/Blog2_xx.jsx", "src/app/_assets/wrapper/Grocery_xx.jsx", "src/app/_assets/wrapper/Navbar_xx.jsx"  ],
  "exclude": ["node_modules"]
}
